<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Laboratoire JNI - Démonstration"
            android:textStyle="bold"
            android:textSize="22sp"
            android:layout_gravity="center_horizontal"
            android:paddingBottom="24dp"
            android:textColor="#333333" />

        <TextView
            android:id="@+id/tvHello"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Attente JNI..."
            android:textSize="18sp"
            android:padding="8dp"
            android:layout_marginBottom="10dp"
            android:background="@android:color/white"
            android:elevation="2dp" />

        <TextView
            android:id="@+id/tvFact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calcul factorielle..."
            android:textSize="18sp"
            android:padding="8dp"
            android:layout_marginBottom="10dp"
            android:background="@android:color/white"
            android:elevation="2dp" />

        <TextView
            android:id="@+id/tvReverse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Inversion de texte..."
            android:textSize="18sp"
            android:padding="8dp"
            android:layout_marginBottom="10dp"
            android:background="@android:color/white"
            android:elevation="2dp" />

        <TextView
            android:id="@+id/tvArray"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calcul somme..."
            android:textSize="18sp"
            android:padding="8dp"
            android:layout_marginBottom="10dp"
            android:background="@android:color/white"
            android:elevation="2dp" />

    </LinearLayout>
</ScrollView>
